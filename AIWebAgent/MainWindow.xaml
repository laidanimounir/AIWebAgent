<Window x:Class="AIWebAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI Web Agent" Height="700" Width="1200" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="25"/>
        </Grid.RowDefinitions>

     
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D2D30">
            <Button Content="🤖 إخفاء/إظهار" Width="140" Margin="10,5" Click="ToggleChat_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <TextBox x:Name="UrlTextBox" Width="500" Margin="5" VerticalContentAlignment="Center" FontSize="14" Text="https://www.google.com"/>
            <Button Content="Go" Width="60" Margin="5" Click="Go_Click" Background="#555" Foreground="White"/>
           
            <ToggleButton x:Name="AiModeToggle" Width="140" Margin="10,5" 
                          Checked="AiModeToggle_Checked" Unchecked="AiModeToggle_Unchecked"
                          Background="#28A745" Foreground="White" FontWeight="Bold"
                          Content="☁️ سحابي (Groq)"/>
        </StackPanel>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" x:Name="ChatColumnDefinition"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid x:Name="ChatPanel" Grid.Column="0" Background="#1E1E1E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="60"/>
                </Grid.RowDefinitions>

               
                <ScrollViewer x:Name="ChatScroller" Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChatMessages" Margin="10"/>
                </ScrollViewer>

               
                <Grid Grid.Row="1" Margin="10,0,10,10" Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CommandInput" Grid.Column="0" Margin="0,0,5,0" 
                             VerticalContentAlignment="Center" FontSize="13"
                             Background="#2D2D30" Foreground="White" 
                             CaretBrush="White" BorderBrush="#555"/>
                    <Button Content="إرسال" Grid.Column="1" Click="SendCommand_Click" 
                            Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                    <Button Content="🗑️" Grid.Column="2" Click="ClearChat_Click" 
                            Background="#CC3300" Foreground="White" Margin="5,0,0,0"/>
                </Grid>
            </Grid>

            
            <wv2:WebView2 x:Name="MainWebView" Grid.Column="1"/>
        </Grid>

  
        <StatusBar Grid.Row="2" Background="#007ACC">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="🟢 جاهز" Foreground="White" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
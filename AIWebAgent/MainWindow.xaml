<Window x:Class="AIWebAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="AI Web Agent" Height="700" Width="1200" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
         
            <RowDefinition Height="*"/>
      
        </Grid.RowDefinitions>

     
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#2D2D30">
            <Button Content="🤖 إخفاء/إظهار الذكاء الاصطناعي" Width="200" Margin="10,5" Click="ToggleChat_Click" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <TextBox x:Name="UrlTextBox" Width="600" Margin="5" VerticalContentAlignment="Center" FontSize="14" Text="https://www.google.com"/>
            <Button Content="اذهب (Go)" Width="80" Margin="5" Click="Go_Click"/>
        </StackPanel>

       
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" x:Name="ChatColumnDefinition"/>
               
                <ColumnDefinition Width="*"/>
               
            </Grid.ColumnDefinitions>

       
            <Grid x:Name="ChatPanel" Grid.Column="0" Background="#F4F4F4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                   
                    <RowDefinition Height="60"/>
             
                </Grid.RowDefinitions>

                <TextBox x:Name="ChatHistory" Grid.Row="0" IsReadOnly="True" Margin="10" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Text="مرحباً! أنا وكيلك الذكي. كيف يمكنني مساعدتك اليوم؟"/>

                <Grid Grid.Row="1" Margin="10,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CommandInput" Grid.Column="0" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"/>
                    <Button Content="إرسال" Grid.Column="1" Background="#28A745" Foreground="White" FontWeight="Bold"/>
                </Grid>
            </Grid>

           
            <wv2:WebView2 x:Name="MainWebView" Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>